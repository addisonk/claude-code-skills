{
  "baseUrl": "http://localhost:3000",

  "_upload_note": "OPTIONAL. Credentials + endpoint/bucket/publicBase come from R2_* env (store them in ~/.claude/settings.json env; see references/uploader.md). Only add an 'upload' block to override per project, e.g. a different keyPrefix or bucket.",
  "upload": {
    "keyPrefix": "qa-artifacts"
  },

  "expo": {
    "appDir": "apps/mobile",
    "metroPort": 8082,
    "serveSimPort": 3210,
    "simulator": "iPhone 16 Pro"
  },

  "theme": {
    "strategy": "class",
    "storageKey": "theme",
    "darkValue": "dark",
    "lightValue": "light"
  },

  "auth": {
    "provider": "clerk",
    "signInPath": "/",
    "signInButton": "Sign in",
    "emailField": "Email address",
    "passwordField": "Password",
    "submitButton": "Sign in"
  },

  "defaults": {
    "viewport": [1440, 900],
    "capture": "both",
    "colorScheme": "dark"
  }
}
